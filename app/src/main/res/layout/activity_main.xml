<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="盯商圈监控"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FF6600" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="状态：已停止"
                android:textSize="14sp"
                android:textColor="#FF4D4F"
                android:padding="6dp"
                android:background="#FFF2F0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="基本设置"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查询间隔（分钟）"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_interval"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="numberDecimal"
                android:text="2"
                android:padding="12dp"
                android:background="@drawable/edit_bg"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="监控列名"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_column_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:text="15min挂单量"
                android:padding="12dp"
                android:background="@drawable/edit_bg"
                android:layout_marginBottom="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提醒条件"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="比较方式"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/sp_comparison"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:entries="@array/comparison_array"
                        android:background="@drawable/edit_bg"
                        android:padding="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="阈值"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_threshold"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="numberDecimal"
                        android:text="0"
                        android:padding="12dp"
                        android:background="@drawable/edit_bg" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="提醒冷却时间（秒）"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_cooldown"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="60"
                android:padding="12dp"
                android:background="@drawable/edit_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_test_sound"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="测试声音"
                android:backgroundTint="#F0F0F0"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="启动监控"
                android:backgroundTint="#FF6600"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="停止监控"
                android:backgroundTint="#FF4D4F"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:enabled="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日志"
            android:textSize="14sp"
            android:textColor="#666666"
            android:paddingBottom="8dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/log_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FAFAFA"
            android:padding="10dp"
            android:minHeight="100dp" />

    </LinearLayout>
</ScrollView>
